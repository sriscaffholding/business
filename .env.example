# ─── Site Configuration ───────────────────────────────────────────────
# Your deployed domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://srivariscaffolding.com

# ─── Google Analytics (Optional but STRONGLY recommended for SEO) ─────
# Get your GA4 Measurement ID from https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Google Search Console Verification (Optional) ───────────────────
# From Google Search Console > Settings > Ownership verification > HTML tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-verification-code-here
